rain_5_day <- function(fastflow_data) {
  fastflow_data <- fastflow_data %>%
    arrange(date) %>%
    mutate(precip_5day = zoo::rollsum(precip, k = 5, fill = NA, align = "right")) %>%
    mutate(precip_5day = ifelse(abs(precip_5day) < 1e-10, 0, precip_5day))
  
  # Find max flow for each year and get corresponding 5-day precipitation
  max_flow_precip <- fastflow_data %>%
    mutate(year = year(date)) %>%
    group_by(year) %>%
    slice_max(Fastflow, n = 1, with_ties = FALSE) %>%
    ungroup() %>%
    select(year, flow = Fastflow, precipitation = precip_5day) %>%
    arrange(year) %>%
    filter(!is.na(flow), !is.na(precipitation), 
           is.finite(flow), is.finite(precipitation),
           flow > 0, precipitation > 0) 
  
  return(max_flow_precip %>% as.data.frame())
}

rain_3_day <- function(fastflow_data) {
  fastflow_data <- fastflow_data %>%
    arrange(date) %>%
    mutate(precip_3day = zoo::rollsum(precip, k = 3, fill = NA, align = "right")) %>%
    mutate(precip_3day = ifelse(abs(precip_3day) < 1e-10, 0, precip_3day))
  
  # Find max flow for each year and get corresponding 3-day precipitation
  max_flow_3precip <- fastflow_data %>%
    mutate(year = year(date)) %>%
    group_by(year) %>%
    slice_max(Fastflow, n = 1, with_ties = FALSE) %>%
    ungroup() %>%
    select(year, flow = Fastflow, precipitation = precip_3day) %>%
    arrange(year) %>%
    filter(!is.na(flow), !is.na(precipitation), 
           is.finite(flow), is.finite(precipitation),
           flow > 0, precipitation > 0)
  
  return(max_flow_3precip %>% as.data.frame())
}

max_daily_rain_before_peak <- function(fastflow_data) {
  fastflow_data <- fastflow_data %>%
    arrange(date)
  
  # Find the date of max flow for each year
  max_flow_dates <- fastflow_data %>%
    mutate(year = year(date)) %>%
    group_by(year) %>%
    slice_max(Fastflow, n = 1, with_ties = FALSE) %>%
    ungroup() %>%
    select(year, max_flow_date = date, max_daily_flow = Fastflow)
  
  # For each max flow date, find the max daily precip in the 5 days before
  results <- max_flow_dates %>%
    rowwise() %>%
    mutate(
      max_daily_precip_5day = {
        five_day_precip <- fastflow_data %>%
          filter(date <= max_flow_date & date > max_flow_date - days(5)) %>%
          pull(precip)
        if(length(five_day_precip) > 0) max(five_day_precip, na.rm = TRUE) else NA
      }
    ) %>%
    ungroup() %>%
    select(year, flow = max_daily_flow, precipitation = max_daily_precip_5day) %>%
    arrange(year) %>%
    filter(!is.na(flow), !is.na(precipitation),
           is.finite(flow), is.finite(precipitation),
           flow > 0, precipitation > 0)
  
  return(results %>% as.data.frame())
}

