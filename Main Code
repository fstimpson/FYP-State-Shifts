hydro_model <- function(catchment_id){
  
  # STEP 1: Get fastflow data first
  cat(sprintf("\n=== Processing catchment: %s ===\n", catchment_id))
  fastflow_data <- fastflow(catchment_id)
  
  # STEP 2: Pass fastflow_data to the rain functions
  five_day_data <- rain_5_day(fastflow_data)
  three_day_data <- rain_3_day(fastflow_data)
  max_daily_rain <- max_daily_rain_before_peak(fastflow_data)
  
  # Verify we have data frames
  cat("Data types:\n")
  cat("  five_day_data:", class(five_day_data), "\n")
  cat("  three_day_data:", class(three_day_data), "\n")
  cat("  max_daily_rain:", class(max_daily_rain), "\n")
  
  # Create list of datasets with names
  data_list <- list(
    "5-Day Rainfall" = five_day_data,
    "3-Day Rainfall" = three_day_data,
    "Max Daily Rainfall" = max_daily_rain
  )
  
  model_states <- c(1, 2, 3)
  
  # Create a list to store all plots
  all_plots <- list()
  plot_counter <- 1
  
  # Your nested loop
  for (data_name in names(data_list)){
    catch_data <- data_list[[data_name]]
    
    cat(sprintf("\n=== Data type: %s ===\n", data_name))
    cat("  Rows:", nrow(catch_data), "\n")
    cat("  Columns:", paste(names(catch_data), collapse = ", "), "\n")
    
    for (n in model_states){
      
      cat(sprintf("\n=== Processing: %s | %d-State Model ===\n", data_name, n))
      
      # Add error handling
      tryCatch({
        Qpeak.model <- build(input.data = catch_data,
                             #data.transform = 'boxcoc',
                             parameters = c('a0','a1','std'),
                             state.shift.parameters = c('a1','std'),
                             error.distribution = 'truc.normal',
                             transition.graph = matrix(TRUE, n, n))
        
        n_params <- length(c('a0','a1','std')) + length(c('a1','std')) * (n - 1)
        
        Qpeak.model <- fit.hydroState(Qpeak.model, 
                                      pop.size.perParameter = 10, 
                                      max.generations = 500, 
                                      doParallel = FALSE)
        
        aic_value <- get.AIC(Qpeak.model)
        cat(sprintf("AIC: %.2f\n", aic_value))
        
        # review residual plots
        plot(Qpeak.model, pse.residuals = TRUE, siteID = catchment_id)
        
        # set the reference year to name the states
        Qpeak.model <- setInitialYear(Qpeak.model, 1990)
        
        # plot all four plots
        plot(Qpeak.model)
        statesProb <- get.states(Qpeak.model)
        
        yearly_summary_states <- catch_data %>%
          inner_join(statesProb, by = c("year" = "Year"))
        
        flood_state <- yearly_summary_states %>%
          rename(state = `Viterbi State Number`)
        
        # Create state labels dynamically based on number of states
        state_levels <- 1:n
        if(n <= length(Qpeak.model@state.labels)){
          state_labels <- Qpeak.model@state.labels[1:n]
        } else {
          state_labels <- paste("State", 1:n)
        }
        
        flood_state$state_label <- factor(
          flood_state$state,
          levels = state_levels,
          labels = state_labels
        )
        
        # Create the plot with CORRECT column names
        p <- ggplot(flood_state, aes(x = precipitation,
                                     y = flow,
                                     colour = state_label)) +
          geom_point(size = 3, alpha = 0.7) +
          geom_smooth(method = "lm", se = TRUE, linewidth = 1.2, linetype = "dashed", alpha = 0.2) +
          labs(
            title = sprintf("%s | %d-State Model", data_name, n),
            subtitle = sprintf("Catchment: %s | AIC: %.1f", catchment_id, aic_value),
            x = "Precipitation (mm)",
            y = "Maximum Daily Flow (mm/d)",
            colour = "Hydrological State"
          ) +
          theme_minimal(base_size = 12) +
          theme(
            plot.title = element_text(face = "bold", size = 14),
            plot.subtitle = element_text(color = "gray40", size = 10),
            legend.position = "right",
            legend.background = element_rect(fill = "white", color = "gray80"),
            panel.grid.minor = element_blank(),
            panel.border = element_rect(fill = NA, color = "gray80")
          )
        
        # Store plot
# Create a structured name: "5day_state2", "3day_state3", etc.
plot_key <- sprintf("%s_state_%d", gsub(" ", "", data_name), n)

all_plots[[plot_key]] <- p
        
        # Print individual plot
        print(p)
        
      }, error = function(e) {
        cat(sprintf("  ERROR: %s\n", e$message))
      })
    }
  }
  
  # Create a combined plot with all successful graphs
  if(length(all_plots) > 0) {
    cat("\n=== Creating combined plot of all 9 models ===\n")
    
    library(gridExtra)
    library(grid)
    
    combined_plot <- grid.arrange(grobs = all_plots, ncol = 3, nrow = 3,
                                  top = textGrob(
                                    sprintf("Precipitation vs Flow Analysis - Catchment %s", catchment_id),
                                    gp = gpar(fontsize = 16, fontface = "bold")
                                  ))
  }
  
  return(all_plots)
}

