annual_flow_summary <- function(catchment_id) {
  combined %>%
    filter(catchment == catchment_id) %>%
    mutate(year = year(date)) %>%
    group_by(year) %>%
    summarise(
      avg_flow = mean(flow_mm, na.rm = TRUE),
      max_flow = max(flow_mm, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    arrange(year)
}

