# ---------------------------

new_filt <- function(a, alpha, alpha1) {
  n <- length(a); if (n == 0) return(a)
  b <- a; yn <- 0; yold <- 0
  a1 <- alpha; a2 <- alpha1
  if (!is.finite(b[1])) b[1] <- 0
  for (i in 2:n) {
    dy <- a[i] - a[i - 1]; if (!is.finite(dy)) dy <- 0
    yn <- a1 * yold + a2 * dy
    if (yn > a[i]) yn <- a[i]
    yb <- a[i] - yn
    if (yb > a[i]) yb <- a[i]
    if (!is.finite(yb)) yb <- 0
    yn   <- a[i] - yb
    yold <- yn
    b[i] <- yb
  }
  b
}

shift <- function(x, n) {
  y <- x; N <- length(x)
  if (N == 0 || n <= 0) return(y)
  if (n >= N) return(y)
  y[(n + 1):N] <- x[1:(N - n)]
  y
}

