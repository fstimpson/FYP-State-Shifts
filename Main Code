fmt_input <- function(s) {
  s <- if (is.null(s)) "" else trimws(s)
  if (identical(s, "")) NA_character_ else s
}

parse_dates <- function(x, fmt = NA_character_) {
  x <- as.character(x)
  x <- trimws(gsub('^"|"$', "", x))
  if (length(x) == 0) return(as.Date(character()))
  if (length(x) >= 1) x[1] <- sub("^\ufeff", "", x[1], useBytes = TRUE) # strip BOM
  
  # user-specified
  if (!is.na(fmt) && nzchar(fmt)) {
    d <- suppressWarnings(as.Date(x, format = fmt))
    if (!all(is.na(d))) return(d)
  }
  
  # ISO (with or without time suffix)
  iso_mask <- grepl("^\\d{4}-\\d{2}-\\d{2}([T\\s].*)?$", x)
  if (any(iso_mask)) {
    xs <- x
    xs[iso_mask] <- substr(xs[iso_mask], 1L, 10L)
    d <- suppressWarnings(as.Date(xs, format = "%Y-%m-%d"))
    if (!all(is.na(d))) return(d)
  }
  
  # common fmts
  fmts <- c("%Y-%m-%d","%Y/%m/%d","%d/%m/%Y","%m/%d/%Y","%d-%m-%Y","%m-%d-%Y")
  for (f in fmts) {
    d <- suppressWarnings(as.Date(x, format = f))
    if (!all(is.na(d))) return(d)
  }
  
  # last resort
  xs <- ifelse(nchar(x) >= 10, substr(x, 1, 10), x)
  suppressWarnings(as.Date(xs))
}

# ---------------------------
# File reader (comments + header auto-detect)
# ---------------------------

.detect_sep <- function(line) {
  if (grepl(",", line, fixed = TRUE)) return(",")
  if (grepl("\t", line)) return("\t")
  ""  # whitespace
}

.is_header_line <- function(line) {
  has_letters <- grepl("[A-Za-z]", line)
  if (has_letters) return(TRUE)
  FALSE
}

read_table_with_comments <- function(path) {
  raw <- readLines(path, warn = FALSE)
  if (length(raw) == 0) stop("Empty file.")
  # skip comments
  i <- 1L
  while (i <= length(raw) && grepl("^\\s*#", raw[i])) i <- i + 1L
  if (i > length(raw)) stop("File has only comment lines.")
  sep <- .detect_sep(raw[i])
  
  header <- .is_header_line(raw[i])
  txt <- paste0(raw[i:length(raw)], collapse = "\n")
  con <- textConnection(txt); on.exit(close(con), add = TRUE)
  
  if (sep == "") {
    df <- tryCatch(utils::read.table(con, header = header, sep = "", stringsAsFactors = FALSE,
                                     check.names = FALSE, comment.char = "", quote = ""),
                   error = function(e) stop("Failed to parse (whitespace) table: ", conditionMessage(e)))
  } else {
    df <- tryCatch(utils::read.table(con, header = header, sep = sep, stringsAsFactors = FALSE,
                                     check.names = FALSE, comment.char = "", quote = "\""),
                   error = function(e) stop("Failed to parse table: ", conditionMessage(e)))
  }
  
  if (ncol(df) < 2) stop("Input must have at least 2 columns (Date, TotalFlow).")
  
  # If no header but first row looks like labels, drop it
  first1 <- as.character(df[[1]][1])
  first2 <- as.character(df[[2]][1])
  looks_like_header <- grepl("date", first1, ignore.case = TRUE) ||
    grepl("flow|discharge|total", first2, ignore.case = TRUE)
  if (!header && looks_like_header) {
    df <- df[-1, , drop = FALSE]
  }
  
  df
}

# ---------------------------
# Safe regressions + single-pass runner
# ---------------------------

safe_blm <- function(B, B1, F1) {
  df <- data.frame(B = B, B1 = B1, F1 = F1)
  if (nrow(df) < 2L) return(list(coef = c(B1 = NA_real_, F1 = NA_real_), adjr2 = NA_real_, ok = FALSE))
  df <- df[-1, , drop = FALSE]
  df <- df[is.finite(rowSums(df)), , drop = FALSE]
  if (nrow(df) < 5L) return(list(coef = c(B1 = NA_real_, F1 = NA_real_), adjr2 = NA_real_, ok = FALSE))
  fit <- try(lm(B ~ -1 + B1 + F1, data = df), silent = TRUE)
  if (!inherits(fit, "try-error") && !is.na(summary(fit)$r.squared)) {
    bc <- coef(fit)
    return(list(
      coef  = c(B1 = unname(ifelse("B1" %in% names(bc), bc["B1"], NA_real_)),
                F1 = unname(ifelse("F1" %in% names(bc), bc["F1"], NA_real_))),
      adjr2 = summary(fit)$adj.r.squared,
      ok    = TRUE
    ))
  }
  fit2 <- try(lm(B ~ -1 + B1, data = df), silent = TRUE)
  if (!inherits(fit2, "try-error") && !is.na(summary(fit2)$r.squared)) {
    bc <- coef(fit2)
    return(list(
      coef  = c(B1 = unname(ifelse("B1" %in% names(bc), bc["B1"], NA_real_)),
                F1 = NA_real_),
      adjr2 = summary(fit2)$adj.r.squared,
      ok    = TRUE
    ))
  }
  list(coef = c(B1 = NA_real_, F1 = NA_real_), adjr2 = NA_real_, ok = FALSE)
}

safe_alm <- function(F, F1, YY1) {
  df <- data.frame(F = F, F1 = F1, YY1 = YY1)
  if (nrow(df) < 2L) return(list(coef = c(F1 = NA_real_), adjr2 = NA_real_, ok = FALSE))
  df <- df[-1, , drop = FALSE]
  df <- df[is.finite(rowSums(df)), , drop = FALSE]
  if (nrow(df) < 5L) return(list(coef = c(F1 = NA_real_), adjr2 = NA_real_, ok = FALSE))
  fit <- try(lm(F ~ -1 + F1 + offset(YY1), data = df), silent = TRUE)
  if (!inherits(fit, "try-error") && !is.na(summary(fit)$r.squared)) {
    return(list(coef = c(F1 = unname(coef(fit)[1])), adjr2 = summary(fit)$adj.r.squared, ok = TRUE))
  }
  fit2 <- try(lm(F ~ -1 + F1, data = df), silent = TRUE)
  if (!inherits(fit2, "try-error") && !is.na(summary(fit2)$r.squared)) {
    return(list(coef = c(F1 = unname(coef(fit2)[1])), adjr2 = summary(fit2)$adj.r.squared, ok = TRUE))
  }
  list(coef = c(F1 = NA_real_), adjr2 = NA_real_, ok = FALSE)
}

#View(cann_data)
run_autovl_single <- function(Date, Y, iterations = 10L) {
  Y <- as.numeric(Y)
  Y[!is.finite(Y)] <- 0
  Y[Y < 0] <- 0
  n <- length(Y)
  if (n < 5L) stop("Not enough rows (>= 5 required).")
  
  Y1 <- shift(Y, 1)
  Ylm <- tryCatch(lm(Y ~ -1 + Y1), error = function(e) NULL)
  alpha_init <- if (!is.null(Ylm)) as.numeric(coef(Ylm)[1]) else NA_real_
  alpha <- if (is.finite(alpha_init)) alpha_init else 0.95
  
  AN <- iterations
  FlowMat <- matrix(NA_real_, nrow = n, ncol = AN)
  Coef    <- matrix(NA_real_, nrow = AN, ncol = 6)
  colnames(Coef) <- c("F_AR","F_adjR2","B_AR","B_MA","unused","B_adjR2")
  alpha_seq <- rep(NA_real_, AN)
  
  for (jj in 1:AN) {
    B <- new_filt(Y, alpha, 1.0)
    F <- Y - B
    
    F1  <- shift(F, 1)
    B1  <- shift(B, 1)
    YY1 <- Y - shift(Y, 1)
    
    blm <- safe_blm(B, B1, F1)
    alm <- safe_alm(F, F1, YY1)
    
    if (!blm$ok) {
      blm$coef  <- c(B1 = ifelse(is.finite(Coef[max(1, jj - 1), 3]), Coef[max(1, jj - 1), 3], 0.95),
                     F1 = 0.0)
      blm$adjr2 <- NA_real_
    }
    if (!alm$ok) {
      alm$coef  <- c(F1 = ifelse(is.finite(Coef[max(1, jj - 1), 1]), Coef[max(1, jj - 1), 1], 0.3))
      alm$adjr2 <- NA_real_
    }
    
    Coef[jj, 1] <- alm$coef["F1"]  # F_AR
    Coef[jj, 2] <- alm$adjr2
    Coef[jj, 3] <- blm$coef["B1"]  # B_AR
    Coef[jj, 4] <- blm$coef["F1"]  # B_MA
    Coef[jj, 6] <- blm$adjr2
    
    FlowMat[, jj] <- B
    
    alpha_raw <- max(Coef[jj, 1], Coef[jj, 3], na.rm = TRUE)
    if (!is.finite(alpha_raw)) alpha_raw <- 0.95
    alpha <- max(min(alpha_raw, 0.999), 0.60)
    alpha_seq[jj] <- alpha
  }
  
  B_final <- FlowMat[, AN]
  F_final <- Y - B_final
  BFI <- if (sum(Y) > 0) sum(B_final) / sum(Y) else NA_real_
  
  list(
    flows = data.frame(Date = Date, TotalFlow = Y, Fastflow = F_final, Baseflow = B_final),
    coef  = data.frame(Iteration = 1:AN, F_AR = Coef[,1], F_adjR2 = Coef[,2],
                       B_AR = Coef[,3], B_MA = Coef[,4], B_adjR2 = Coef[,6],
                       Alpha = alpha_seq),
    iter  = { df <- data.frame(Date = Date, FlowMat); names(df)[-1] <- paste0("B_iter_", 1:AN); df },
    diag  = data.frame(SeriesLength = n, Iterations = AN,
                       AlphaInit = alpha_init, AlphaFinal = alpha, BFI = BFI)
  )
}

